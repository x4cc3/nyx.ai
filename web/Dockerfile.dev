FROM node:20-alpine

ENV npm_config_fetch_retries=5 \
    npm_config_fetch_retry_factor=2 \
    npm_config_fetch_retry_maxtimeout=120000 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_network_timeout=300000

WORKDIR /app/web

# Install dependencies at build time (not at runtime).
COPY package.json package-lock.json ./
RUN for i in 1 2 3; do \
      npm ci --no-audit --no-fund && exit 0; \
      if [ "$i" -eq 3 ]; then exit 1; fi; \
      sleep $((i * 5)); \
    done

# Source is bind-mounted at runtime; this layer just ensures deps exist.
CMD ["sh", "-lc", "if [ ! -x node_modules/.bin/next ]; then for i in 1 2 3; do npm ci --no-audit --no-fund && break; if [ \"$i\" -eq 3 ]; then exit 1; fi; sleep $((i * 5)); done; fi; npm run dev -- --hostname 0.0.0.0 --port 3000"]
