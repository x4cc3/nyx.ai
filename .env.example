NYX_BROWSER_MODE=auto
NYX_BROWSER_TIMEOUT=20s
NYX_BROWSER_ARTIFACTS_ROOT=/tmp/nyx-browser
NYX_BROWSER_HEADLESS=true
NYX_BROWSER_EXECUTABLE=
