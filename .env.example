NYX_DLQ_STREAM=NYX_DLQ
NYX_DLQ_SUBJECT=nyx.dlq
NYX_QUEUE_MAX_DELIVER=3
NYX_ACTION_RESULT_TIMEOUT=30s
NYX_EXECUTOR_MODE=auto
